# DATABASE_URL: Local SQLite database file.
DATABASE_URL="file:./aivoc.db"

# OPENAI-compatible LLM settings used for classify + dashboard helpers.
OPENAI_API_KEY="YOUR_OPENAI_COMPATIBLE_API_KEY"
OPENAI_BASE_URL="https://maas-llm-aiplatform-hcm.api.vngcloud.vn/v1"
OPENAI_MODEL="gpt-4.1-mini"

# Optional compatibility aliases for older server helpers.
LLM_API_KEY="YOUR_OPENAI_COMPATIBLE_API_KEY"
LLM_BASE_URL="https://maas-llm-aiplatform-hcm.api.vngcloud.vn/v1"
LLM_MODEL="gpt-4.1-mini"

# External source integrations.
YOUTUBE_API_KEY=""
OPENCLAW_URL=""
OPENCLAW_TOKEN=""

# APP_URL: The URL where this applet is hosted.
# AI Studio automatically injects this at runtime with the Cloud Run service URL.
# Used for self-referential links, OAuth callbacks, and API endpoints.
APP_URL="MY_APP_URL"
